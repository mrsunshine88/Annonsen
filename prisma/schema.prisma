generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password         String
  autoLocation     Boolean   @default(true) // För IP-baserad platsigenkänning
  defaultLocation  String?   // Sparat Län
  isAdmin          Boolean   @default(false)
  isRoot           Boolean   @default(false) // Skyddar kontot från att tas bort eller ändras i admin
  isBlocked        Boolean   @default(false)
  termsAccepted    Boolean   @default(false) // Måste godkännas vid inloggning
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Företagsfält
  accountType        String    @default("Privat") // "Privat" eller "Företag"
  companyPageApproved Boolean  @default(false)
  canPublishAds      Boolean   @default(false)
  companyName        String?
  companyOrgNr       String?
  companyAddress     String?
  companyZipCode     String?
  companyCity        String?
  companyWebsite     String?
  companyLogoUrl     String?
  companyDescription String?
  companyOpeningHours String?
  companyPhone       String?

  // Unika företagspriser
  customCompanyAdPrice           Int?
  customCompanySubscriptionPrice Int?

  // Unika arbetsgivarpriser
  customEmployerAdPrice           Int?
  customEmployerSubscriptionPrice Int?

  // Stripe B2B Fakturering
  stripeCustomerId               String?  @unique
  stripeSubscriptionId           String?
  stripeSubscriptionItemId       String?  // För metered billing
  hasActiveSubscription          Boolean  @default(false)

  ads              Ad[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  
  // Jobb-relationer
  jobAds           JobAd[]
  jobApplications  JobApplication[]
  
  // Nya relationer
  favorites        Favorite[]
  following        Follow[]  @relation("Follower")
  followers        Follow[]  @relation("Followed")
  reportsSubmitted AdReport[]
}

model Category {
  id       String  @id @default(cuid())
  name     String  @unique
  parentId String?

  parent        Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  subcategories Category[] @relation("CategoryToCategory")
  ads           Ad[]
  customPrice   Int? // Eget pris för denna kategori (skriver över standard)
}

model Ad {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Int
  imageUrls   String[]
  phoneNumber String?
  hidePhone   Boolean  @default(false)
  isPaid      Boolean  @default(true) // Sätts till false om betalning krävs
  paymentId   String?  // Swish payment request ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Generella filter
  location       String? // Län
  city           String? // Ort (t.ex. Ramdala)
  zipCode        String? // Postnummer (t.ex. 37352)
  advertiserType String? // Privat, Företag

  // Fordonsspecifika filter
  mileage    Int? // Miltal
  color      String? // Färg
  gearbox    String? // Växellåda
  brand      String? // Bilmärke
  model      String? // Modell
  year       Int? // Modellår
  fuel       String? // Drivmedel
  drivetrain String? // Drivhjul
  horsepower Int? // Hästkrafter

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  messages Message[]
  favorites Favorite[]
  reports  AdReport[]

  @@index([categoryId])
  @@index([location])
  @@index([authorId])
  @@index([createdAt])
  @@index([price])
  @@index([title, brand, model])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
  readAt    DateTime?
  isJobMessage Boolean @default(false)
  deletedBySender Boolean @default(false)
  deletedByReceiver Boolean @default(false)

  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  adId String?
  ad   Ad?     @relation(fields: [adId], references: [id], onDelete: Cascade)

  jobAdId String?
  jobAd   JobAd?  @relation(fields: [jobAdId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([adId])
}

model Settings {
  id              String  @id @default("default")
  paymentsEnabled Boolean @default(false)
  defaultAdPrice  Int     @default(0)
  swishMode       String  @default("TEST") // "TEST" eller "LIVE"
  swishAlias      String? // 123xxxxxxx
  swishCert       String? // Sökväg/innehåll för cert
  swishKey        String? // Sökväg/innehåll för nyckel
  bumpEnabled     Boolean @default(false)
  bumpPrice       Int     @default(0)
  
  // Företagspriser
  companyAdPrice           Int @default(0) // Pris per annons för företag
  companySubscriptionPrice Int @default(0) // Månadskostnad för företagssida

  // Arbetsgivarpriser
  employerAdPrice           Int @default(0) // Pris per platsannons för arbetsgivare
  employerSubscriptionPrice Int @default(0) // Månadskostnad för arbetsgivare
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adId      String
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, adId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followedId  String
  followed    User     @relation("Followed", fields: [followedId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followedId])
}

model AdReport {
  id          String   @id @default(cuid())
  reason      String
  status      String   @default("Ny") // "Ny", "Hanterad"
  adminViewed Boolean  @default(false)
  userId      String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  adId      String
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobAd {
  id              String   @id @default(cuid())
  title           String   // Jobbtitel
  companyName     String   // Vem som anställer
  industry        String   // Bransch
  
  location        String   // Plats eller "Distans"
  scope           String   // Heltid, deltid, extrajobb, projekt
  duration        String   // Tillsvidare, vikariat osv.
  vacancies       Int      @default(1) // Antal platser
  
  description     String   // Fritext
  requirements    String   // Ska-krav
  merits          String?  // Meriterande
  
  deadline        DateTime // Sista ansökningsdag
  applyUrl        String?  // Om ansökan sker externt
  contactPerson   String?  // Namn
  contactEmail    String?  // E-post
  contactPhone    String?  // Telefon
  hideContactPhone Boolean  @default(false)
  
  isPaid          Boolean  @default(true)
  paymentId       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  applications    JobApplication[]
  messages        Message[]

  @@index([authorId])
  @@index([createdAt])
}

model JobApplication {
  id              String   @id @default(cuid())
  
  name            String
  email           String
  phone           String?
  message         String?
  
  cvUrl           String
  coverLetterUrl  String
  
  status          String   @default("Ny") // "Ny" eller "Hanterad"

  createdAt       DateTime @default(now())

  jobId           String
  job             JobAd    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  applicantId     String
  applicant       User     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
}

model Transaction {
  id               String   @id @default(uuid())
  swishReference   String   @unique // Detta fält stoppar dubbelbetalningar på databasnivå
  amount           Int
  adId             String
  createdAt        DateTime @default(now())
}

model VerificationToken {
  id         String   @id @default(uuid())
  identifier String   // Användarens e-post
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
